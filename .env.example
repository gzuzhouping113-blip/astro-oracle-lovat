# Public deployed URL, used for Open Graph and Twitter metadata.
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app

# Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Volcengine Ark / Doubao API key. Used by default for dream interpretation,
# card copy, prompt polishing, and SeedDream image generation.
DOUBAO_API_KEY=your_doubao_api_key_here

# Optional Doubao text model override.
DOUBAO_TEXT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_TEXT_MODEL=doubao-seed-1-6-251015

# Optional OpenAI-compatible text model override. If CUSTOM_AI_API_KEY is set,
# dream interpretation and card copy use this provider instead of Doubao text.
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=
CUSTOM_AI_MODEL=gpt-5.5
