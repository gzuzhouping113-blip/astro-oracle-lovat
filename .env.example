# Public deployed URL, used for Open Graph and Twitter metadata.
NEXT_PUBLIC_SITE_URL=https://dreamdrop.cn

# Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI-compatible text model service used by dream interpretation, card copy,
# and image prompt polishing.
CUSTOM_AI_API_KEY=your_text_model_api_key_here
CUSTOM_AI_BASE_URL=https://www.lansekafei.asia/v1
CUSTOM_AI_MODEL=gpt-5.4-mini

# OpenAI-compatible image generation service.
GPT_IMAGE_API_KEY=your_image_model_api_key_here
GPT_IMAGE_BASE_URL=https://www.lansekafei.asia/v1
GPT_IMAGE_MODEL=gpt-image-2
GPT_IMAGE_SIZE=1024x1024

# Optional hosts allowed by /api/image-proxy for HTTP image URLs returned by
# third-party image providers.
IMAGE_PROXY_ALLOWED_HOSTS=154.217.234.133

# Optional China filing information. Leave empty until the official filing numbers
# are issued, then configure these in Vercel Environment Variables.
NEXT_PUBLIC_ICP_BEIAN=
NEXT_PUBLIC_POLICE_BEIAN=
NEXT_PUBLIC_POLICE_BEIAN_URL=
