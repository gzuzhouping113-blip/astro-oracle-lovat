# Public deployed URL, used for Open Graph and Twitter metadata.
NEXT_PUBLIC_SITE_URL=https://your-vercel-app.vercel.app

# Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenAI-compatible text model service used by dream interpretation and card copy.
CUSTOM_AI_API_KEY=your_custom_ai_api_key_here
CUSTOM_AI_BASE_URL=https://your-openai-compatible-api.example.com/v1

# Optional text model override. Defaults to gpt-5.5 in the API routes.
CUSTOM_AI_MODEL=gpt-5.5

# Volcengine Ark / Doubao SeedDream image generation API key.
DOUBAO_API_KEY=your_doubao_api_key_here
